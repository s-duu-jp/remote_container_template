{
  "service": "app",
  "workspaceFolder": "/workspace",
  "dockerComposeFile": "docker-compose.yml",
  "initializeCommand": "bash -x .devcontainer/sh/initializeCommand.sh",
  "postCreateCommand": "bash -x .devcontainer/sh/postCreateCommand.sh",
  "postStartCommand": "bash -x .devcontainer/sh/postStartCommand.sh",
  "shutdownAction": "stopCompose",
  "features": {
    "docker-from-docker": {
      "version": "latest"
    }
  },
  "forwardPorts": [],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.defaultProfile.windows": "/bin/bash",
        "terminal.integrated.defaultProfile.osx": "/bin/bash",
        "terminal.integrated.shellIntegration.enabled": false,
        "js/ts.preferences.importModuleSpecifier": "project-relative",
        "files.trimTrailingWhitespace": true,
        "explorer.compactFolders": false,
        "editor.guides.bracketPairs": true,
        "editor.bracketPairColorization.enabled": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": [
          "source.addMissingImports",
          "source.fixAll.eslint"
        ]
      },
      "extensions": [
        "esbenp.prettier-vscode",
        "bierner.markdown-mermaid",
        "eamodio.gitlens",
        "GitHub.copilot"
      ]
    }
  }
}
